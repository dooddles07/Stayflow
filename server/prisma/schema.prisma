generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipTier {
  SIGNATURE
  PRESTIGE
  ELITE
}

enum BookingStatus {
  CONFIRMED
  PENDING
  CANCELLED
}

enum FacilityStatus {
  OPEN
  MAINTENANCE
  CLOSED
}

enum TableStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
}

enum DiningReservationStatus {
  CONFIRMED
  PENDING
  CANCELLED
  ARRIVED
}

enum GuestStatus {
  PENDING
  APPROVED
  CHECKED_IN
  CHECKED_OUT
}

enum PortalRole {
  MEMBER
  STAFF
  MANAGEMENT
}

model Resident {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  phone             String
  unit              String
  tier              MembershipTier
  avatarSeed        String
  avatarStyle       String?
  moveInDate        DateTime
  dietary           String[]
  notifications     Boolean        @default(true)
  newsletter        Boolean        @default(true)
  emergencyName     String
  emergencyRelation String
  emergencyPhone    String

  // Optional secondary emergency contact.
  emergency2Name     String?
  emergency2Relation String?
  emergency2Phone    String?

  // Last time the resident opened the notices feed — anything newer is "unread".
  noticesLastSeenAt DateTime?

  family             FamilyMember[]
  vehicles           Vehicle[]
  bookings           Booking[]
  diningReservations DiningReservation[]
  guests             Guest[]
  eventRsvps         EventRsvp[]
  user               User?

  @@map("residents")
}

model FamilyMember {
  id         String   @id @default(cuid())
  name       String
  relation   String
  age        Int
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@map("family_members")
}

model Vehicle {
  id         String   @id @default(cuid())
  make       String
  model      String
  plate      String
  color      String
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@map("vehicles")
}

model StaffMember {
  id         String @id @default(cuid())
  name       String
  role       String
  email      String @unique
  shift      String
  avatarSeed String

  user User?

  @@map("staff_members")
}

model Facility {
  id           String         @id @default(cuid())
  name         String
  category     String
  description  String
  rules        String[]
  image        String
  capacity     Int
  openHours    String
  status       FacilityStatus @default(OPEN)
  statusReason String?
  rating       Float
  location     String

  bookings Booking[]

  @@map("facilities")
}

model Booking {
  id         String        @id @default(cuid())
  facilityId String
  facility   Facility      @relation(fields: [facilityId], references: [id])
  residentId String
  resident   Resident      @relation(fields: [residentId], references: [id])
  date       DateTime      @db.Date
  timeSlot   String
  partySize  Int
  status     BookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())

  @@map("bookings")
}

model Restaurant {
  id          String @id @default(cuid())
  name        String
  cuisine     String
  description String
  image       String
  openHours   String
  priceRange  String
  rating      Float
  location    String

  tables       DiningTable[]
  reservations DiningReservation[]

  @@map("restaurants")
}

model DiningTable {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  label        String
  seats        Int
  status       TableStatus @default(AVAILABLE)

  reservations DiningReservation[]

  @@map("dining_tables")
}

model DiningReservation {
  id           String                  @id @default(cuid())
  restaurantId String
  restaurant   Restaurant              @relation(fields: [restaurantId], references: [id])
  residentId   String
  resident     Resident                @relation(fields: [residentId], references: [id])
  tableId      String?
  table        DiningTable?            @relation(fields: [tableId], references: [id])
  date         DateTime                @db.Date
  time         String
  partySize    Int
  occasion     String?
  dietary      String?
  seating      String
  status       DiningReservationStatus @default(PENDING)
  createdAt    DateTime                @default(now())

  @@map("dining_reservations")
}

model Guest {
  id             String      @id @default(cuid())
  name           String
  hostResidentId String
  hostResident   Resident    @relation(fields: [hostResidentId], references: [id])
  purpose        String
  vehiclePlate   String?
  arrivalDate    DateTime    @db.Date
  arrivalTime    String
  passNumber     String      @unique
  status         GuestStatus @default(PENDING)
  checkedInAt    DateTime?
  checkedOutAt   DateTime?

  @@map("guests")
}

model CommunityEvent {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String
  image       String
  date        DateTime @db.Date
  time        String
  endTime     String?
  location    String
  capacity    Int

  rsvps EventRsvp[]

  @@map("events")
}

model EventRsvp {
  id         String         @id @default(cuid())
  eventId    String
  event      CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  residentId String
  resident   Resident       @relation(fields: [residentId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([eventId, residentId])
  @@map("event_rsvps")
}

model Notice {
  id       String   @id @default(cuid())
  title    String
  category String
  body     String
  postedAt DateTime @default(now())
  postedBy String
  pinned   Boolean  @default(false)

  @@map("notices")
}

model AppNotification {
  id        String   @id @default(cuid())
  kind      String
  title     String
  body      String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@map("notifications")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         PortalRole
  displayName  String
  createdAt    DateTime   @default(now())
  tokenVersion Int        @default(0)
  isActive     Boolean    @default(true)

  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  resetTokenHash      String?   @unique
  resetTokenExpiresAt DateTime?

  // Email change stays pending until the user clicks the link sent to the NEW address.
  pendingEmail        String?   @unique
  emailTokenHash      String?   @unique
  emailTokenExpiresAt DateTime?

  residentId String?      @unique
  resident   Resident?    @relation(fields: [residentId], references: [id])
  staffId    String?      @unique
  staff      StaffMember? @relation(fields: [staffId], references: [id])

  @@map("users")
}

// Immutable auth audit trail. Intentionally NOT related to User (no FK) so events
// outlive the account they describe — deleting a user must not erase their history.
model AuthEvent {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  email     String?
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("auth_events")
}
